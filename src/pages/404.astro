---
import Base from '../layouts/Base.astro';
---

<Base title="404 — Page Not Found">
	<div class="not-found">
		<h1>404</h1>
		<p>This page doesn't exist.</p>
		<a href="/">Go home</a>
	</div>
</Base>

<style>
	.not-found {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		min-height: 60vh;
		text-align: center;
		gap: 1rem;
	}

	h1 {
		font-size: 6rem;
		font-weight: 800;
		opacity: 0.15;
		line-height: 1;
	}
</style>
